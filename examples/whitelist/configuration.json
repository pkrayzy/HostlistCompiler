{
  "name": "AdGuard Allowlist",
  "description": "Combination of allowlists for use with AdGuard DNS.",
  "homepage": "https://github.com/AdguardTeam/AdguardSDNSFilter",
  "license": "GPLv3",
  "sources": [
    {
      "name": "Hagezi Blocklist Referrals",
      "source": "https://raw.githubusercontent.com/hagezi/dns-blocklists/main/adblock/blocklist-referral-native.txt",
      "type": "adblock",
      "transformations": [
        "RemoveModifiers",
        "Compress",
        "Validate"
      ]
    },
    {
      "name": "AdGuard Allowlist",
      "source": "https://raw.githubusercontent.com/pkrayzy/HostlistCompiler/master/optimized/dns_whitelist.txt",
      "type": "adblock",
      "transformations": [
        "RemoveModifiers",
        "Compress",
        "Validate"
      ]
    },
    {
      "name": "Personal Allowlist",
      "source": "https://raw.githubusercontent.com/pkrayzy/HostlistCompiler/master/optimized/dns_exclusions.txt",
      "type": "adblock",
      "transformations": [
        "RemoveModifiers",
        "Compress",
        "Validate"
      ]
    }
  ],
  "transformations": [
    "Deduplicate",
    "RemoveComments",
    "Compress"
  ],
  "exclusions": ["doubleclick.net", "google.com", "googleadservices.com"]
}